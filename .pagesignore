# Cloudflare Pages deploy ignore — beastcorestudios-website

# Self-exclude (deploy-control file is not a public artifact)
.pagesignore

# Source maps (never serve to public)
*.map

# Common build artifacts
node_modules/
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/

# Env / secrets (defense in depth)
.env
.env.*
*.env

# Local repo state
.git/
.gitignore
.gitattributes

# Local build-tool state
.wrangler/

# Editor / IDE / agent local state
.claude/
.vscode/

# CI internals
.github/

# Internal repo docs (not for public consumption)
DEPLOY_CHECKLIST.md
README.md
CHANGELOG.md

# Internal demo / draft pages
*-demo*.html
*-internal.html
*.draft.html
